print("Starting server on port 8080...")
http_serve(8080, def(req) {
    path = req["path"]
    if path == "/" {
        return {"status": 200, "body": "<h1>Hello from Aether!</h1>", "content_type": "text/html"}
    }
    if path == "/api/hello" {
        return {"status": 200, "body": json_encode({"message": "Hello!"}), "content_type": "application/json"}
    }
    return {"status": 404, "body": "Not Found"}
})
