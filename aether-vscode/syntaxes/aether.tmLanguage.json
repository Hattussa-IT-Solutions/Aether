{
  "name": "Aether",
  "scopeName": "source.aether",
  "fileTypes": ["ae"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#decorators" },
    { "include": "#directives" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#constants" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.aether", "match": "//.*$" },
        { "name": "comment.block.aether", "begin": "/\\*", "end": "\\*/" }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.aether",
          "begin": "\"\"\"",
          "end": "\"\"\""
        },
        {
          "name": "string.quoted.double.aether",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.aether", "match": "\\\\." },
            {
              "name": "meta.interpolation.aether",
              "begin": "\\{",
              "end": "\\}",
              "beginCaptures": { "0": { "name": "punctuation.definition.interpolation.begin.aether" } },
              "endCaptures": { "0": { "name": "punctuation.definition.interpolation.end.aether" } },
              "patterns": [{ "include": "source.aether" }]
            }
          ]
        },
        {
          "name": "string.quoted.raw.aether",
          "begin": "r\"",
          "end": "\""
        },
        {
          "name": "string.quoted.single.aether",
          "begin": "'",
          "end": "'"
        }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.hex.aether", "match": "\\b0[xX][0-9a-fA-F_]+\\b" },
        { "name": "constant.numeric.binary.aether", "match": "\\b0[bB][01_]+\\b" },
        { "name": "constant.numeric.float.aether", "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9]+)?\\b" },
        { "name": "constant.numeric.integer.aether", "match": "\\b[0-9][0-9_]*\\b" }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.aether",
          "match": "\\b(if|else|match|guard|for|in|loop|times|while|until|step|break|next|return|try|catch|finally|throw|parallel|after|device)\\b"
        },
        {
          "name": "keyword.declaration.aether",
          "match": "\\b(def|let|const|class|struct|enum|interface|impl|mod|use|type|async|await)\\b"
        },
        {
          "name": "keyword.modifier.aether",
          "match": "\\b(pub|priv|prot|readonly|static|lazy|override|operator)\\b"
        },
        {
          "name": "keyword.other.aether",
          "match": "\\b(self|super|init|deinit|as|with|where|then|and|or|not)\\b"
        },
        {
          "name": "keyword.genetic.aether",
          "match": "\\b(genetic|gene|chromosome|fitness|crossover|breed|evolve|mutation|evolving|reactive|temporal)\\b"
        },
        {
          "name": "keyword.oop.aether",
          "match": "\\b(weave|bond|face|extend|delegate|select|exclude|morph)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.aether",
          "match": "\\b(Int|Float|Num|Bool|Str|Char|Byte|Nil|Int8|Int16|Int32|Int64|UInt8|UInt16|UInt32|UInt64|Float32|Float64|List|Map|Set|Result|Tensor|Self)\\b"
        }
      ]
    },
    "decorators": {
      "patterns": [
        { "name": "meta.decorator.aether", "match": "@[a-zA-Z_][a-zA-Z0-9_]*" }
      ]
    },
    "directives": {
      "patterns": [
        { "name": "meta.directive.aether", "match": "#[a-zA-Z_][a-zA-Z0-9_]*" }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.aether", "match": "\\|>|\\?\\.|\\.\\.|\\.\\.=|=>|->|\\?\\?" }
      ]
    },
    "functions": {
      "patterns": [
        { "name": "entity.name.function.aether", "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()" }
      ]
    },
    "constants": {
      "patterns": [
        { "name": "constant.language.aether", "match": "\\b(true|false|nil|PI|E|TAU|INF)\\b" }
      ]
    }
  }
}
