{
  "name": "aether-language",
  "displayName": "Aether Language",
  "description": "Full IDE support for the Aether programming language — IntelliSense, debugging, syntax highlighting",
  "version": "0.2.0",
  "publisher": "hattussa-it",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Programming Languages", "Debuggers", "Snippets"],
  "activationEvents": [
    "onLanguage:aether",
    "onDebugResolve:aether",
    "onCommand:aether.run",
    "onCommand:aether.debug"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [{
      "id": "aether",
      "aliases": ["Aether", "aether"],
      "extensions": [".ae"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "aether",
      "scopeName": "source.aether",
      "path": "./syntaxes/aether.tmLanguage.json"
    }],
    "snippets": [{
      "language": "aether",
      "path": "./snippets.json"
    }],
    "commands": [
      {
        "command": "aether.run",
        "title": "Aether: Run Current File",
        "icon": "$(play)"
      },
      {
        "command": "aether.debug",
        "title": "Aether: Debug Current File",
        "icon": "$(debug-alt)"
      },
      {
        "command": "aether.repl",
        "title": "Aether: Open REPL"
      },
      {
        "command": "aether.check",
        "title": "Aether: Type Check Current File"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "command": "aether.run",
          "when": "resourceLangId == aether",
          "group": "navigation@1"
        },
        {
          "command": "aether.debug",
          "when": "resourceLangId == aether",
          "group": "navigation@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "aether.run",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "resourceLangId == aether"
      },
      {
        "command": "aether.debug",
        "key": "f5",
        "when": "resourceLangId == aether && !inDebugMode"
      }
    ],
    "breakpoints": [
      { "language": "aether" }
    ],
    "debuggers": [
      {
        "type": "aether",
        "label": "Aether Debug",
        "program": "./out/debugAdapter.js",
        "runtime": "node",
        "languages": ["aether"],
        "configurationAttributes": {
          "launch": {
            "required": ["program"],
            "properties": {
              "program": {
                "type": "string",
                "description": "Aether source file to debug",
                "default": "${file}"
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Stop on the first line",
                "default": false
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "aether",
            "request": "launch",
            "name": "Debug Aether",
            "program": "${file}"
          }
        ],
        "configurationSnippets": [
          {
            "label": "Aether: Launch",
            "description": "Debug an Aether program",
            "body": {
              "type": "aether",
              "request": "launch",
              "name": "Debug Aether",
              "program": "^\"\\${file}\""
            }
          }
        ]
      }
    ],
    "configuration": {
      "title": "Aether",
      "properties": {
        "aether.path": {
          "type": "string",
          "default": "aether",
          "description": "Path to the aether binary"
        },
        "aether.checkOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run type checker on save"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^2.0.0"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  }
}
