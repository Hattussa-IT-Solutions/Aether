// Edge case tests: OOP stress
print("=== OOP Tests ===")

// 1. Deep inheritance chain (5 levels)
class Level0 {
    val: Int = 0
    init() { self.val = 0 }
    def get_level() { return 0 }
    def get_val() { return self.val }
}

class Level1 : Level0 {
    init() { self.val = 1 }
    def get_level() { return 1 }
}

class Level2 : Level1 {
    init() { self.val = 2 }
    def get_level() { return 2 }
}

class Level3 : Level2 {
    init() { self.val = 3 }
    def get_level() { return 3 }
}

class Level4 : Level3 {
    init() { self.val = 4 }
    def get_level() { return 4 }
}

l0 = Level0()
l1 = Level1()
l2 = Level2()
l3 = Level3()
l4 = Level4()

print("L0 val:", l0.get_val(), "level:", l0.get_level())
print("L1 val:", l1.get_val(), "level:", l1.get_level())
print("L2 val:", l2.get_val(), "level:", l2.get_level())
print("L3 val:", l3.get_val(), "level:", l3.get_level())
print("L4 val:", l4.get_val(), "level:", l4.get_level())

// Inherited method from base class still works
print("L4 get_val from Level0:", l4.get_val())

// 2. Class with many fields (20)
class BigClass {
    f1: Int = 0
    f2: Int = 0
    f3: Int = 0
    f4: Int = 0
    f5: Int = 0
    f6: Int = 0
    f7: Int = 0
    f8: Int = 0
    f9: Int = 0
    f10: Int = 0
    f11: Int = 0
    f12: Int = 0
    f13: Int = 0
    f14: Int = 0
    f15: Int = 0
    f16: Int = 0
    f17: Int = 0
    f18: Int = 0
    f19: Int = 0
    f20: Int = 0

    init() {
        self.f1 = 1
        self.f2 = 2
        self.f3 = 3
        self.f4 = 4
        self.f5 = 5
        self.f6 = 6
        self.f7 = 7
        self.f8 = 8
        self.f9 = 9
        self.f10 = 10
        self.f11 = 11
        self.f12 = 12
        self.f13 = 13
        self.f14 = 14
        self.f15 = 15
        self.f16 = 16
        self.f17 = 17
        self.f18 = 18
        self.f19 = 19
        self.f20 = 20
    }

    def sum_all() {
        return self.f1 + self.f2 + self.f3 + self.f4 + self.f5 + self.f6 + self.f7 + self.f8 + self.f9 + self.f10 + self.f11 + self.f12 + self.f13 + self.f14 + self.f15 + self.f16 + self.f17 + self.f18 + self.f19 + self.f20
    }
}

big = BigClass()
print("BigClass f1:", big.f1)
print("BigClass f20:", big.f20)
print("BigClass sum:", big.sum_all())

// Modify fields
big.f1 = 100
big.f20 = 200
print("After modify f1:", big.f1)
print("After modify f20:", big.f20)

// 3. Many instances creation (1000)
class Counter {
    id: Int = 0
    count: Int = 0

    init(id) {
        self.id = id
        self.count = 0
    }

    def inc() {
        self.count += 1
    }

    def get() {
        return self.count
    }
}

instances = []
for i in 0..1000 {
    instances.push(Counter(i))
}
print("created instances:", instances.len())
print("instance[0] id:", instances[0].id)
print("instance[999] id:", instances[999].id)

// Operate on many instances
for i in 0..1000 {
    instances[i].inc()
    instances[i].inc()
    instances[i].inc()
}
print("instance[0] count:", instances[0].get())
print("instance[500] count:", instances[500].get())
print("instance[999] count:", instances[999].get())

// 4. Operator overloading
class Vec2 {
    x: Float
    y: Float

    init(x, y) {
        self.x = x
        self.y = y
    }

    operator +(other) {
        return Vec2(self.x + other.x, self.y + other.y)
    }

    operator -(other) {
        return Vec2(self.x - other.x, self.y - other.y)
    }

    operator *(other) {
        return Vec2(self.x * other, self.y * other)
    }

    def magnitude() {
        return sqrt(self.x ** 2 + self.y ** 2)
    }

    def to_str() {
        return "({self.x}, {self.y})"
    }
}

v1 = Vec2(3.0, 4.0)
v2 = Vec2(1.0, 2.0)

v3 = v1 + v2
print("v1 + v2:", v3.to_str())

v4 = v1 - v2
print("v1 - v2:", v4.to_str())

v5 = v1 * 2.0
print("v1 * 2:", v5.to_str())

print("v1 magnitude:", v1.magnitude())

// Chain operations
v6 = (v1 + v2) * 3.0
print("(v1+v2)*3:", v6.to_str())

// 5. Method override in child class
class Shape {
    name: Str = "shape"

    init(name) {
        self.name = name
    }

    def area() {
        return 0.0
    }

    def describe() {
        return "{self.name}: area = {self.area()}"
    }
}

class Circle : Shape {
    radius: Float = 0.0

    init(r) {
        self.name = "circle"
        self.radius = r
    }

    def area() {
        return PI * self.radius ** 2
    }
}

class Rectangle : Shape {
    width: Float = 0.0
    height: Float = 0.0

    init(w, h) {
        self.name = "rectangle"
        self.width = w
        self.height = h
    }

    def area() {
        return self.width * self.height
    }
}

c = Circle(5.0)
r = Rectangle(3.0, 4.0)
print("Circle:", c.describe())
print("Rectangle:", r.describe())

// 6. Self-referencing methods
class LinkedNode {
    value: Int = 0
    label: Str = ""

    init(value) {
        self.value = value
        self.label = "node-{value}"
    }

    def double_value() {
        self.value = self.value * 2
        return self
    }

    def get_info() {
        return "{self.label}: {self.value}"
    }
}

node = LinkedNode(5)
print("before:", node.get_info())
node.double_value()
print("after double:", node.get_info())

// 7. Class with methods that create other instances
class Point {
    x: Float = 0.0
    y: Float = 0.0

    init(x, y) {
        self.x = x
        self.y = y
    }

    def offset(dx, dy) {
        return Point(self.x + dx, self.y + dy)
    }

    def midpoint(other) {
        return Point((self.x + other.x) / 2, (self.y + other.y) / 2)
    }
}

p1 = Point(0.0, 0.0)
p2 = Point(10.0, 10.0)
mid = p1.midpoint(p2)
print("midpoint:", mid.x, mid.y)

p3 = p1.offset(3.0, 4.0)
print("offset:", p3.x, p3.y)

// 8. Multiple classes interacting
class Engine {
    hp: Int = 0
    init(hp) { self.hp = hp }
    def describe() { return "{self.hp}hp engine" }
}

class Car {
    make: Str = ""
    engine: Str = ""

    init(make, engine) {
        self.make = make
        self.engine = engine
    }

    def describe() {
        return "{self.make} with {self.engine}"
    }
}

e = Engine(200)
car = Car("Aether Motors", e.describe())
print("Car:", car.describe())

print("=== All OOP tests passed ===")
