pass_count = 0
fail_count = 0
def assert_eq(actual, expected) {
    if actual == expected { pass_count += 1 }
    else { fail_count += 1; print("FAIL: expected", expected, "got", actual) }
}
def assert_true(v) { assert_eq(v, true) }
def assert_false(v) { assert_eq(v, false) }

// === Empty list ===
assert_eq([].len(), 0)
assert_eq([].is_empty(), true)
assert_eq([].first(), nil)
assert_eq([].last(), nil)
assert_eq([].sum(), 0)
assert_eq([].reverse(), [])
assert_eq([].sort(), [])

// === Single element list ===
assert_eq([42].len(), 1)
assert_eq([42].first(), 42)
assert_eq([42].last(), 42)
assert_eq([42].sum(), 42)
assert_true([42].contains(42))
assert_false([42].contains(43))

// === List methods ===
l = [3, 1, 4, 1, 5, 9, 2, 6]
assert_eq(l.len(), 8)
assert_eq(l.min(), 1)
assert_eq(l.max(), 9)
assert_eq(l.sort(), [1, 1, 2, 3, 4, 5, 6, 9])
assert_eq(l.reverse().len(), 8)
assert_true(l.contains(4))
assert_false(l.contains(99))
assert_eq(l.index_of(4), 2)
assert_eq(l.index_of(99), -1)

// === push/pop ===
m = [1, 2, 3]
m.push(4)
assert_eq(m.len(), 4)
assert_eq(m.last(), 4)
v = m.pop()
assert_eq(v, 4)
assert_eq(m.len(), 3)

// === map/filter/reduce ===
nums = [1, 2, 3, 4, 5]
assert_eq(nums.map(x -> x * 2), [2, 4, 6, 8, 10])
assert_eq(nums.filter(x -> x > 3), [4, 5])
assert_eq(nums.reduce(0, (a, b) -> a + b), 15)

// === take/drop ===
assert_eq([1,2,3,4,5].take(3), [1, 2, 3])
assert_eq([1,2,3,4,5].take(0), [])
assert_eq([1,2,3,4,5].take(99), [1, 2, 3, 4, 5])
assert_eq([1,2,3,4,5].drop(2), [3, 4, 5])
assert_eq([1,2,3,4,5].drop(0), [1, 2, 3, 4, 5])

// === compact ===
assert_eq([1, nil, 2, nil, 3].compact(), [1, 2, 3])
assert_eq([nil, nil].compact(), [])

// === flatten ===
assert_eq([[1,2],[3,4],[5]].flatten(), [1, 2, 3, 4, 5])
assert_eq([].flatten(), [])

// === unique ===
assert_eq([1,2,2,3,3,3].unique(), [1, 2, 3])

// === join ===
assert_eq(["a","b","c"].join(", "), "a, b, c")
assert_eq([].join(","), "")

// === get (safe access) ===
assert_eq([10,20,30].get(1), 20)
assert_eq([10,20,30].get(99), nil)
assert_eq([].get(0), nil)

// === find/find_index ===
assert_eq([1,2,3,4,5].find(x -> x > 3), 4)
assert_eq([1,2,3].find(x -> x > 10), nil)
assert_eq([1,2,3,4,5].find_index(x -> x > 3), 3)

// === any/all ===
assert_true([1,2,3].any(x -> x > 2))
assert_false([1,2,3].any(x -> x > 5))
assert_true([1,2,3].all(x -> x > 0))
assert_false([1,2,3].all(x -> x > 2))

// === chunks/window ===
assert_eq([1,2,3,4,5].chunks(2).len(), 3)
assert_eq([1,2,3,4,5].window(3).len(), 3)

// === frequencies ===
freq = ["a","b","a","c","a","b"].frequencies()
assert_eq(freq["a"], 3)
assert_eq(freq["b"], 2)

// === zip ===
assert_eq([1,2,3].zip([4,5,6]).len(), 3)

// === concat ===
assert_eq([1,2].concat([3,4]), [1, 2, 3, 4])
assert_eq([].concat([1]), [1])

// === Empty map ===
em = {}
assert_eq(em.len(), 0)
assert_true(em.is_empty())
assert_eq(em.keys(), [])

// === Map operations ===
m2 = {"a": 1, "b": 2, "c": 3}
assert_eq(m2.len(), 3)
assert_true(m2.contains_key("a"))
assert_false(m2.contains_key("z"))
assert_eq(m2.get("a"), 1)
assert_eq(m2.get_or("z", 99), 99)
assert_eq(m2.get_or("a", 99), 1)

// === Set operations ===
s1 = {1, 2, 3}
s2 = {2, 3, 4}
assert_eq(s1.len(), 3)
assert_true(s1.contains(2))
assert_false(s1.contains(9))
assert_eq(s1.union(s2).len(), 4)
assert_eq(s1.intersect(s2).len(), 2)
assert_eq(s1.difference(s2).len(), 1)

total = pass_count + fail_count
print("{pass_count}/{total} collection tests passed")
